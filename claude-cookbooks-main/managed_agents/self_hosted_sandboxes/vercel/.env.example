# Issued by Anthropic when you register the webhook (whsec_...)
ANTHROPIC_WEBHOOK_SECRET=

# The self-hosted environment id (env_01...)
ANTHROPIC_ENVIRONMENT_ID=

# The environment key — the single credential for work poll/ack/stop and the
# runner's per-session calls (sk-ant-oat...)
ANTHROPIC_ENVIRONMENT_KEY=

# Optional. Defaults to https://api.anthropic.com.
# ANTHROPIC_BASE_URL=
